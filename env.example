# autonomous-claude environment
# Copy to ~/.config/autonomous-claude/env (mode 600) and paste your token.
# Generate a long-lived token with `claude setup-token`.
export CLAUDE_CODE_OAUTH_TOKEN=

# Optional: override where the vault lives (default: $HOME/autonomous-vault).
# export VAULT_ROOT="$HOME/ai-documents/ai-projects/autonomous"

# Optional: override the claude binary path (default: first `claude` on PATH).
# export CLAUDE_BIN="$HOME/.local/bin/claude"
